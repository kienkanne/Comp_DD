parm /localscratch/kbui/NexusMol/build/md_test_data/2BPW.prmtop
trajin /localscratch/kbui/NexusMol/build/md_test_data/2BPW_seed0.nc

autoimage
strip :Na+,Cl-,WAT


# RMS analysis
rmsd first :1-198@CA out rmsd_2BPW.out
atomicfluct out rmsf_bb_2BPW.dat @CA,C,N byres


# Hydrogen bonds analysis
# --- Protein–Protein hydrogen bonds ---
hbond ProtProt :1-198 out PP_hbvtime_2BPW.dat avgout PP_avg_2BPW.dat

# --- Protein–Water hydrogen bonds ---
hbond All :1-198 solventdonor :WAT solventacceptor :WAT@O out All_hbvtime_2BPW.dat solvout PW_avg_2BPW.dat bridgeout Bridge_avg_2BPW.dat

# --- Backbone-only protein hydrogen bonds ---
hbond BB_Prot :1-198@C,O,N,H avgout BB_avg_2BPW.dat series uuseries BB_series_2BPW.dat

# --- Create time-series counts ---
create PW_hbvtime_2BPW.dat All[UV]
create Bridge_hbvtime_2BPW.dat All[Bridge]
create BB_hbvtime_2BPW.dat BB_Prot[UU]


# Secondary structure analysis
secstruct out ss_per_res_2BPW.dat sumout summary_ss_2BPW.dat totalout total_2BPW.out


# PCA analysis
average @N,C,CA crdset trajaverage
createcrd trajectory
run

crdaction trajectory rms ref trajaverage @N,C,CA
crdaction trajectory matrix covar name covmatrix @N,C,CA
runanalysis diagmatrix covmatrix out evecs.dat vecs 10 name eigenvectors \
nmwiz nmwizvecs 10 nmwizfile normalmodes.nmd nmwizmask @N,C,CA

crdaction trajectory projection modes eigenvectors beg 1 end 10 \
@N,C,CA out pca_protein.dat


# Clustering
cluster c1 \
 kmeans clusters 5 randompoint maxit 500 \
 rms :1-198@C,N,O,CA,CB \
 sieve 10 random \
 out cnumvtime_2BPW.dat \
 summary summary_2BPW.dat \
 info info_2BPW.dat \
 cpopvtime cpopvtime_2BPW.agr normframe \
 repout rep_2BPW repfmt pdb \
 singlerepout singlerep_2BPW.nc singlerepfmt netcdf \
 avgout avg_2BPW avgfmt pdb

run
quit